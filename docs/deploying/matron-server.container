[Container]
Environment=MATRON_SERVER_SERVER_NAME=your.domain.here MATRON_SERVER_DATABASE_PATH=/var/lib/matron-server MATRON_SERVER_PORT=6167 MATRON_SERVER_MAX_REQUEST_SIZE=20000000 MATRON_SERVER_ALLOW_REGISTRATION=true MATRON_SERVER_REGISTRATION_TOKEN=YOUR_TOKEN MATRON_SERVER_ALLOW_FEDERATION=true MATRON_SERVER_TRUSTED_SERVERS=["matrix.org"] MATRON_SERVER_ADDRESS=0.0.0.0 # Add MATRON_SERVER_CONFIG: '/etc/matron-server.toml' if the config is mapped
Image=docker.io/matronhq/matron-server:latest
PublishPort=8448:6167
Volume=/path/to/db:/var/lib/matron-server
#Volume=/path/to/matron-server.toml:/etc/matron-server.toml #Uncomment to use the config file

[Service]
Restart=always
